pipeline {
    agent any
    stages {

        stage('Checkout') {
            steps {
                git branch: 'master', url: 'https://github.com/jangamajay/jenkins.git'
            }
        }

        stage('Build') {
            steps {
                dir('javaapp-standalone') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('javaapp-standalone') {
                    sh 'mvn test'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('javaapp-standalone') {
                    withSonarQubeEnv('SonarQube') {
                        sh 'mvn sonar:sonar'
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }

    post {
        success {
            mail to: 'ajayr.akula@gmail.com',
                 subject: 'SUCCESS: Build Passed ✅',
                 body: 'Build and SonarQube Quality Gate passed successfully.'
        }

        failure {
            mail to: 'ajayr.akula@gmail.com',
                 subject: 'FAILURE: Build Failed ❌',
                 body: 'Build or Quality Gate failed. Check Jenkins & SonarQube.'
        }
    }
}
